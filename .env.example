# Optional: Auth token for the Stick Buddy API server
# Generate with: python3 -c "import secrets; print(secrets.token_hex(16))"
STICK_BUDDY_TOKEN=

# Optional: VPS URL for the BLE central daemon (Windows-side)
# Set this if you use --config instead of --url
STICK_BUDDY_URL=https://your-vps.tailnet:9120